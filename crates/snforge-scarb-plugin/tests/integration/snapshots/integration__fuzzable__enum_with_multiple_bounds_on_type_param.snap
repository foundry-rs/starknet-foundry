impl FuzzableBoundedImpl<
    T, +snforge_std::fuzzable::Fuzzable<T>, +core::fmt::Debug<T>, +core::clone::Clone<T>, +Drop<T>,
> of snforge_std::fuzzable::Fuzzable<Bounded<T, _, _>> {
    fn blank() -> Bounded<T, _, _> {
        Bounded::Value(snforge_std::fuzzable::Fuzzable::<T>::blank())
    }
    fn generate() -> Bounded<T, _, _> {
        let variant_idx = snforge_std::fuzzable::generate_arg(0, 1);
        match variant_idx {
            0 => { Bounded::Value(snforge_std::fuzzable::Fuzzable::<T>::generate()) },
            1 => { Bounded::Empty },
            _ => panic!("unexpected value of generate_arg cheatcode"),
        }
    }
}
